# WingLoan Backend Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
SERVER_PORT=8080

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_at_least_64_characters_long

# Database Configuration (Supabase)
# Note: prepareThreshold=0 is required for Supabase connection pooler (transaction mode)
DB_URL=jdbc:postgresql://aws-0-REGION.pooler.supabase.com:6543/postgres?prepareThreshold=0
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=your_database_password

# AI Configuration (Optional)
ANTHROPIC_API_KEY=
